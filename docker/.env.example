# md-MIDI2IP container configuration (EPIC-17).
# Passed to orchestrator.py by docker/run-orchestrator.sh.

HOST=0.0.0.0
PORT=5005           # game TCP port (ST/Pico, Hatari --transport tcp)
WS_PORT=5006        # WebSocket port (browser midi-maze-js, Hatari --transport ws)
HTTP_PORT=8080      # HTTP status page + rooms REST API
ADMIN_KEY=          # required for REST room writes; empty refuses writes
ROOM_TTL=600        # seconds before an empty room is reaped
ROOMS_FILE=/data/rooms.json   # provisioned rooms persist here (mount /data)
